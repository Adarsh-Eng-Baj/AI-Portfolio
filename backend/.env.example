# =============================================
# Portfolio Backend — Environment Variables
# Copy this file to .env and fill in your values
# =============================================

# Flask
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-here-make-it-long

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here-also-long

# Database (leave empty for SQLite in development)
# Format: postgresql://user:password@host:port/dbname
# Supabase example: postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Admin credentials (used to seed the first admin user)
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Adarsh Sutar

# OpenAI (optional — chatbot works without this via rule-based fallback)
OPENAI_API_KEY=

# CORS — comma-separated origins (use * for dev)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,https://your-portfolio.vercel.app
